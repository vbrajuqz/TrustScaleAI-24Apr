# ---------- Database ----------
# Railway will inject DATABASE_URL automatically when you add a Postgres plugin
DATABASE_URL="postgresql://user:pass@host:5432/dbname?schema=public"

# ---------- NextAuth / Auth.js ----------
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"
# Your deployed URL (no trailing slash). For local dev use http://localhost:3000
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ---------- Google OAuth ----------
# From https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------- Microsoft Entra ID (Azure AD) ----------
# From https://entra.microsoft.com App registrations
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
# Use "common" to allow any Microsoft account, or a specific tenant GUID
AZURE_AD_TENANT_ID="common"
